# Upstash Redis Environment Variables (Required for Production Scaling)
# Get these from your Upstash console (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Vertex AI / Gemini API Key (Optional fallback if not using VM service account authentication)
VERTEX_AI_KEY=your_vertex_ai_key_here

